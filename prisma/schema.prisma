generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  MASTER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum AppointmentSource {
  INTERNAL
  ONLINE
  BOT
  PHONE
  OTHER
}

enum ScheduleBlockType {
  DAY_OFF
  VACATION
  SICK_LEAVE
  TRAINING
  DO_NOT_BOOK
  BREAK
  LUNCH
  PERSONAL
  TECHNICAL
}

enum EmergencyExportType {
  TODAY
  TOMORROW
  SEVEN_DAYS
  THIRTY_DAYS
  CUSTOM
}

enum EmergencyExportStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ExportStorage {
  LOCAL
  S3
}

enum ManagerNoteType {
  MANAGER
  OWNER
}

enum BookingRequestStatus {
  NEW
  CONTACTED
  CLOSED
}

enum BookingRequestType {
  MANAGER_REQUEST
  CONSULTATION_REQUEST
  RESCHEDULE_REQUEST
}

enum BookingRequestSource {
  ONLINE
}

enum PromotionType {
  GIFT
  SEASONAL
  GAME
  BUNDLE
  CONSULTATION
  CUSTOM
  DISCOUNT
}

enum DiscountUnit {
  PERCENT
  FIXED
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ClientStatus {
  NEW
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ClientDuplicateReviewStatus {
  REVIEW
  NOT_DUPLICATE
  POSTPONED
}

enum LoginThrottleScope {
  ACCOUNT
  IP
}

enum PromotionSource {
  MANUAL
  GAME
  VK
  BOT
  SEASONAL
}

enum GameCatalogType {
  CATCH_TIME
  WHEEL_OF_FORTUNE
}

enum GameCatalogStatus {
  DRAFT
  ACTIVE
  DISABLED
  ARCHIVED
}

enum GameSessionStatus {
  ACTIVE
  COMPLETED
  CONSUMED
  EXPIRED
}

enum GameGiftActivationMode {
  SINGLE_PAID_SERVICE
  COURSE_MIN_SESSIONS
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  passwordHash      String    @map("password_hash")
  role              UserRole
  name              String
  phone             String?
  positionTitle     String?   @map("position_title")
  notes             String?
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  master                  Master?
  createdAppointments     Appointment[]           @relation("AppointmentCreatedBy")
  createdBlocks           ScheduleBlock[]         @relation("BlockCreatedBy")
  createdExtraWorkWindows ExtraWorkWindow[]       @relation("ExtraWorkCreatedBy")
  managerNotes            ManagerNote[]
  requestedExports        EmergencyExport[]       @relation("ExportRequestedBy")
  auditLogs               AuditLog[]
  clientDuplicateReviews  ClientDuplicateReview[] @relation("DuplicateReviewedBy")
  clientsMergedBy         Client[]                @relation("ClientMergedBy")
  clientMergeLogs         ClientMergeLog[]        @relation("ClientMergePerformedBy")
  botSettingsUpdated      BotSettings[]           @relation("BotSettingsUpdatedBy")
  passwordResetTokens     PasswordResetToken[]
  communicationImports    CommunicationImportJob[] @relation("CommunicationImportCreatedBy")
  communicationCampaignsCreated CommunicationCampaign[] @relation("CommunicationCampaignCreatedBy")
  communicationCampaignsUpdated CommunicationCampaign[] @relation("CommunicationCampaignUpdatedBy")
  legalDocumentVersionsCreated LegalDocumentVersion[] @relation("LegalDocumentVersionCreatedBy")

  @@map("users")
}

model LoginThrottleEntry {
  id              String             @id @default(uuid()) @db.Uuid
  scope           LoginThrottleScope
  keyHash         String             @map("key_hash") @db.VarChar(64)
  failedCount     Int                @default(0) @map("failed_count")
  windowStartedAt DateTime           @map("window_started_at") @db.Timestamptz
  blockedUntil    DateTime?          @map("blocked_until") @db.Timestamptz
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([scope, keyHash])
  @@index([blockedUntil])
  @@index([windowStartedAt])
  @@map("login_throttle_entries")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Master {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String?  @unique @map("user_id") @db.Uuid
  internalName           String   @map("internal_name")
  publicName             String   @map("public_name")
  clientDescription      String?  @map("client_description")
  photoUrl               String?  @map("photo_url")
  slotMinutes            Int      @default(30) @map("slot_minutes")
  workStart              String   @map("work_start")
  workEnd                String   @map("work_end")
  breakAfterMinutes      Int      @default(0) @map("break_after_minutes")
  usesDefaultWorkHours   Boolean  @default(false) @map("uses_default_work_hours")
  sortOrder              Int      @default(0) @map("sort_order")
  isActive               Boolean  @default(true) @map("is_active")
  isPublic               Boolean  @default(true) @map("is_public")
  isOnlineBookingEnabled Boolean  @default(true) @map("is_online_booking_enabled")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  masterServices   MasterService[]
  appointments     Appointment[]
  scheduleBlocks   ScheduleBlock[]
  extraWorkWindows ExtraWorkWindow[]
  bookingLinks     BookingLink[]
  bookingRequests  BookingRequest[]

  @@map("masters")
}

model ServiceCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  services Service[]

  @@map("service_categories")
}

model Service {
  id                     String   @id @default(uuid()) @db.Uuid
  categoryId             String   @map("category_id") @db.Uuid
  internalName           String   @map("internal_name")
  publicName             String   @map("public_name")
  clientDescription      String?  @map("client_description")
  durationMinutes        Int      @map("duration_minutes")
  breakAfterMinutes      Int      @default(0) @map("break_after_minutes")
  price                  Decimal? @db.Decimal(10, 2)
  priceFrom              Decimal? @map("price_from") @db.Decimal(10, 2)
  priceTo                Decimal? @map("price_to") @db.Decimal(10, 2)
  sortOrder              Int      @default(0) @map("sort_order")
  isActive               Boolean  @default(true) @map("is_active")
  isPublic               Boolean  @default(true) @map("is_public")
  isOnlineBookingEnabled Boolean  @default(true) @map("is_online_booking_enabled")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  category       ServiceCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  synonyms       ServiceSynonym[]
  masterServices MasterService[]
  appointments   Appointment[]
  bookingLinks   BookingLink[]
  bookingRequests BookingRequest[]
  promotions     PromotionService[]

  @@map("services")
}

model ServiceSynonym {
  id        String   @id @default(uuid()) @db.Uuid
  serviceId String   @map("service_id") @db.Uuid
  synonym   String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([serviceId, synonym])
  @@map("service_synonyms")
}

model MasterService {
  masterId                  String   @map("master_id") @db.Uuid
  serviceId                 String   @map("service_id") @db.Uuid
  isEnabled                 Boolean  @default(true) @map("is_enabled")
  isPublic                  Boolean  @default(true) @map("is_public")
  isOnlineBookingEnabled    Boolean  @default(true) @map("is_online_booking_enabled")
  durationMinutesOverride   Int?     @map("duration_minutes_override")
  breakAfterMinutesOverride Int?     @map("break_after_minutes_override")
  priceOverride             Decimal? @map("price_override") @db.Decimal(10, 2)
  sortOrder                 Int      @default(0) @map("sort_order")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz

  master  Master  @relation(fields: [masterId], references: [id], onDelete: Restrict)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([masterId, serviceId])
  @@map("master_services")
}

model Appointment {
  id                        String            @id @default(uuid()) @db.Uuid
  masterId                  String            @map("master_id") @db.Uuid
  serviceId                 String?           @map("service_id") @db.Uuid
  startsAt                  DateTime          @map("starts_at") @db.Timestamptz
  endsAt                    DateTime          @map("ends_at") @db.Timestamptz
  clientName                String            @map("client_name")
  clientPhone               String            @map("client_phone")
  comment                   String?
  importantNote             String?           @map("important_note")
  isBold                    Boolean           @default(false) @map("is_bold")
  serviceDurationMinutes    Int?              @map("service_duration_minutes")
  breakAfterMinutes         Int?              @map("break_after_minutes")
  standardDurationMinutes   Int?              @map("standard_duration_minutes")
  standardBreakAfterMinutes Int?              @map("standard_break_after_minutes")
  isManualTimeOverride      Boolean           @default(false) @map("is_manual_time_override")
  status                    AppointmentStatus @default(SCHEDULED)
  source                    AppointmentSource @default(INTERNAL)
  promoCode                 String?           @map("promo_code")
  appliedPromotions         Json?             @map("applied_promotions")
  botSessionId              String?           @map("bot_session_id")
  /**
   * Phase A EXPAND: plaintext dual-write for rollback to pre-hash app images.
   * Phase B CONTRACT (follow-up): stop writing plaintext, then drop column.
   */
  manageToken               String?           @unique @map("manage_token")
  /** SHA-256 hex of manage bearer. Primary lookup key in Phase A+ apps. */
  manageTokenHash           String?           @unique @map("manage_token_hash")
  cancelledBy               String?           @map("cancelled_by")
  cancelReason              String?           @map("cancel_reason")
  rescheduleRequestText     String?           @map("reschedule_request_text")
  rescheduleRequestedAt     DateTime?         @map("reschedule_requested_at") @db.Timestamptz
  createdByUserId           String?           @map("created_by_user_id") @db.Uuid
  clientId                  String?           @map("client_id") @db.Uuid
  cancelledAt               DateTime?         @map("cancelled_at") @db.Timestamptz
  createdAt                 DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  master        Master   @relation(fields: [masterId], references: [id], onDelete: Restrict)
  service       Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdByUser User?    @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  rescheduleRequests BookingRequest[]
  legalAcceptanceRecords LegalAcceptanceRecord[]

  @@index([masterId, startsAt, endsAt])
  @@index([startsAt])
  @@index([clientId])
  @@map("appointments")
}

model ScheduleBlock {
  id              String            @id @default(uuid()) @db.Uuid
  masterId        String?           @map("master_id") @db.Uuid
  blockDate       DateTime?         @map("block_date") @db.Date
  startsAt        DateTime?         @map("starts_at") @db.Timestamptz
  endsAt          DateTime?         @map("ends_at") @db.Timestamptz
  isFullDay       Boolean           @default(false) @map("is_full_day")
  blockType       ScheduleBlockType @map("block_type")
  internalReason  String?           @map("internal_reason")
  createdByUserId String?           @map("created_by_user_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  master        Master? @relation(fields: [masterId], references: [id], onDelete: Cascade)
  createdByUser User?   @relation("BlockCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([masterId, startsAt, endsAt])
  @@index([masterId, blockDate])
  @@index([startsAt])
  @@map("schedule_blocks")
}

model ExtraWorkWindow {
  id                     String   @id @default(uuid()) @db.Uuid
  masterId               String   @map("master_id") @db.Uuid
  workDate               DateTime @map("work_date") @db.Date
  startsAt               DateTime @map("starts_at") @db.Timestamptz
  endsAt                 DateTime @map("ends_at") @db.Timestamptz
  isOnlineBookingEnabled Boolean  @default(false) @map("is_online_booking_enabled")
  comment                String?
  createdByUserId        String?  @map("created_by_user_id") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  master        Master @relation(fields: [masterId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("ExtraWorkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([masterId, workDate])
  @@index([startsAt])
  @@map("extra_work_windows")
}

model ManagerNote {
  id              String          @id @default(uuid()) @db.Uuid
  noteDate        DateTime        @map("note_date") @db.Date
  noteType        ManagerNoteType @default(MANAGER) @map("note_type")
  content         String
  createdByUserId String?         @map("created_by_user_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([noteDate])
  @@index([noteDate, noteType])
  @@map("manager_notes")
}

model BookingLink {
  id           String    @id @default(uuid()) @db.Uuid
  token        String    @unique
  serviceId    String?   @map("service_id") @db.Uuid
  masterId     String?   @map("master_id") @db.Uuid
  source       String?
  promoCode    String?   @map("promo_code")
  botSessionId String?   @map("bot_session_id")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  isUsed       Boolean   @default(false) @map("is_used")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  master  Master?  @relation(fields: [masterId], references: [id], onDelete: SetNull)

  @@map("booking_links")
}

model BookingRequest {
  id          String               @id @default(uuid()) @db.Uuid
  clientName  String               @map("client_name")
  clientPhone String               @map("client_phone")
  /**
   * Canonical digits for open-game uniqueness (normalizePhone).
   * Partial unique index is migration-only — see booking_requests_open_game_phone_catalog_uidx.
   */
  clientPhoneNormalized String?    @map("client_phone_normalized")
  comment     String?
  masterId    String?              @map("master_id") @db.Uuid
  serviceId   String?              @map("service_id") @db.Uuid
  serviceNameSnapshot String?      @map("service_name_snapshot")
  /**
   * Set for game leads only (from GamePlay.gameCatalogId). Enables per-catalog open uniqueness.
   */
  gameCatalogId String?            @map("game_catalog_id") @db.Uuid
  status      BookingRequestStatus @default(NEW)
  source      BookingRequestSource @default(ONLINE)
  type        BookingRequestType
  clientId    String?              @map("client_id") @db.Uuid
  appointmentId String?            @map("appointment_id") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  idempotencyKey         String? @unique @map("idempotency_key")
  idempotencyPayloadHash String? @map("idempotency_payload_hash") @db.VarChar(64)

  master       Master?       @relation(fields: [masterId], references: [id], onDelete: SetNull)
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  gameCatalog  GameCatalog?  @relation(fields: [gameCatalogId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  botEventLogs BotEventLog[]
  gamePlay     GamePlay?     @relation("GamePlayLead")
  legalAcceptanceRecords LegalAcceptanceRecord[]

  @@index([status, createdAt(sort: Desc)])
  @@index([clientId])
  @@index([appointmentId])
  @@index([serviceId])
  @@index([clientPhoneNormalized])
  @@index([gameCatalogId])
  @@map("booking_requests")
}

model EmergencyExport {
  id                String                @id @default(uuid()) @db.Uuid
  exportType        EmergencyExportType   @map("export_type")
  periodFrom        DateTime              @map("period_from") @db.Date
  periodTo          DateTime              @map("period_to") @db.Date
  filePath          String?               @map("file_path")
  storage           ExportStorage         @default(LOCAL)
  status            EmergencyExportStatus @default(PENDING)
  errorMessage      String?               @map("error_message")
  requestedByUserId String?               @map("requested_by_user_id") @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz
  completedAt       DateTime?             @map("completed_at") @db.Timestamptz

  requestedByUser User? @relation("ExportRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("emergency_exports")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id") @db.Uuid
  payload        Json?
  previousValues Json?    @map("previous_values")
  newValues      Json?    @map("new_values")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model ChangeEvent {
  id                String   @id @default(uuid()) @db.Uuid
  eventType         String   @map("event_type")
  entityType        String   @map("entity_type")
  entityId          String   @map("entity_id") @db.Uuid
  payloadAnonymized Json?    @map("payload_anonymized")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@map("change_events")
}

model GameConfig {
  /**
   * Singleton-конфигурация игры.
   */
  id          String  @id @default("default")
  isActive    Boolean @default(false) @map("is_active")
  title       String  @default("Поймай своё время")
  description String  @default("")
  image       String? @map("image")

  resultHeaderText     String @default("Ваш результат готов ✨") @map("result_header_text")
  directionLabelText   String @default("Ваше направление ухода:") @map("direction_label_text")
  giftLabelText        String @default("Ваш подарок:") @map("gift_label_text")
  ctaButtonText        String @default("Получить подарок и записаться") @map("cta_button_text")
  ctaButtonLink        String @default("/promo/procedure-gift") @map("cta_button_link")
  managerMessageHeader String @default("Здравствуйте!\n\nЯ прошла игру «Поймай своё время».") @map("manager_message_header")
  managerMessageFooter String @default("Хочу узнать условия получения подарка и записаться.") @map("manager_message_footer")

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("game_config")
}

model GameGift {
  id               String  @id @default(uuid()) @db.Uuid
  name             String
  shortDescription String  @map("short_description")
  image            String? @map("image")
  isActive         Boolean @default(true) @map("is_active")
  probability      Int     @default(0)

  /**
   * Категоризация подарка для UI/аналитики.
   */
  priority  String @default("standard")
  cardStyle String @default("default") @map("card_style")

  /**
   * Правила доступности: пустой массив = доступно для всех.
   */
  allowedGameDirections String[] @default([]) @map("allowed_game_directions")
  allowedResultTypes    String[] @default([]) @map("allowed_result_types")
  requiredPremiumLevel  Int      @default(0) @map("required_premium_level")

  /**
   * Условие получения подарка (фиксируется в giftSnapshot при результате).
   * SINGLE_PAID_SERVICE — одна оплачиваемая процедура по направлению.
   * COURSE_MIN_SESSIONS — курс минимум из minCourseSessions процедур.
   */
  activationMode            GameGiftActivationMode @default(SINGLE_PAID_SERVICE) @map("activation_mode")
  minCourseSessions         Int?                   @map("min_course_sessions")
  activationConditionText   String                 @default("") @map("activation_condition_text")

  gameCatalogId String?      @map("game_catalog_id") @db.Uuid
  gameCatalog   GameCatalog? @relation(fields: [gameCatalogId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  plays GamePlay[]

  @@index([isActive])
  @@index([probability])
  @@index([gameCatalogId])
  @@index([activationMode])
  @@map("game_gifts")
}

model GamePlay {
  id            String @id @default(uuid()) @db.Uuid
  gameDirection String @map("game_direction")
  skinNeed      String @map("skin_need")
  resultType    String @map("result_type")
  premiumLevel  Int    @default(0) @map("premium_level")

  gameCatalogId String?      @map("game_catalog_id") @db.Uuid
  gameCatalog   GameCatalog? @relation(fields: [gameCatalogId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  gameSessionId String?      @unique @map("game_session_id") @db.Uuid
  gameSession   GameSession? @relation(fields: [gameSessionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  selectedGiftId String?   @map("selected_gift_id") @db.Uuid
  selectedGift   GameGift? @relation(fields: [selectedGiftId], references: [id], onDelete: SetNull)

  serverResultTier Int     @default(0) @map("server_result_tier")
  campaignKey      String? @map("campaign_key")
  rulesVersion     String? @map("rules_version")
  giftSnapshot     Json?   @map("gift_snapshot")
  rulesSnapshot    Json?   @map("rules_snapshot")
  clientMetrics    Json?   @map("client_metrics")

  leadId String?         @unique @map("lead_id") @db.Uuid
  lead   BookingRequest? @relation("GamePlayLead", fields: [leadId], references: [id], onDelete: Restrict, onUpdate: Cascade)

