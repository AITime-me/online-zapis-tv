  utmSource              String             @default("vk") @map("utm_source")
  utmMedium              String             @default("messenger") @map("utm_medium")
  utmCampaign            String?            @map("utm_campaign")
  stats                  Json?
  recipientSnapshotAt    DateTime?          @map("recipient_snapshot_at") @db.Timestamptz
  contentLockedAt        DateTime?          @map("content_locked_at") @db.Timestamptz
  createdByUserId        String?            @map("created_by_user_id") @db.Uuid
  updatedByUserId        String?            @map("updated_by_user_id") @db.Uuid
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  segment     CommunicationSegment?            @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  mediaAsset  CommunicationMediaAsset?         @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  createdBy   User?                            @relation("CommunicationCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy   User?                            @relation("CommunicationCampaignUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  buttons     CommunicationCampaignButton[]
  recipients  CommunicationCampaignRecipient[]
  events      CommunicationEvent[]
  redirects   CommunicationRedirectToken[]
  deliveryAttempts CommunicationDeliveryAttempt[]

  @@index([status])
  @@index([segmentId])
  @@index([mediaAssetId])
  @@map("communication_campaigns")
}

model CommunicationCampaignButton {
  id          String          @id @default(uuid()) @db.Uuid
  campaignId  String          @map("campaign_id") @db.Uuid
  text        String
  type        CommButtonType
  buttonKey   String          @map("button_key")
  action      String?
  url         String?
  promotionId String?         @map("promotion_id") @db.Uuid
  sortOrder   Int             @default(0) @map("sort_order")
  style       CommButtonStyle @default(SECONDARY)

  campaign CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, buttonKey])
  @@index([campaignId, sortOrder])
  @@map("communication_campaign_buttons")
}

model CommunicationCampaignRecipient {
  id          String   @id @default(uuid()) @db.Uuid
  campaignId  String   @map("campaign_id") @db.Uuid
  contactId   String   @map("contact_id") @db.Uuid
  status      String   @default("PENDING")
  queuedAt    DateTime? @map("queued_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  campaign CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  CommunicationContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events   CommunicationEvent[]

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@map("communication_campaign_recipients")
}

model CommunicationImportJob {
  id              String               @id @default(uuid()) @db.Uuid
  status          CommImportJobStatus  @default(PREVIEWED)
  originalFileName String?             @map("original_file_name")
  fileKind        String               @map("file_kind")
  summary         Json
  errorMessage    String?              @map("error_message")
  createdByUserId String?              @map("created_by_user_id") @db.Uuid
  appliedAt       DateTime?            @map("applied_at") @db.Timestamptz
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz

  createdBy User? @relation("CommunicationImportCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@map("communication_import_jobs")
}

model CommunicationEvent {
  id          String        @id @default(uuid()) @db.Uuid
  type        CommEventType
  contactId   String?       @map("contact_id") @db.Uuid
  campaignId  String?       @map("campaign_id") @db.Uuid
  recipientId String?       @map("recipient_id") @db.Uuid
  buttonKey   String?       @map("button_key")
  occurredAt  DateTime      @default(now()) @map("occurred_at") @db.Timestamptz
  metadata    Json?

  contact   CommunicationContact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  campaign  CommunicationCampaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  recipient CommunicationCampaignRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([type, occurredAt(sort: Desc)])
  @@index([campaignId, type])
  @@index([contactId, type])
  @@map("communication_events")
}

model CommunicationRedirectToken {
  id             String    @id @default(uuid()) @db.Uuid
  tokenHash      String    @unique @map("token_hash") @db.VarChar(64)
  campaignId     String    @map("campaign_id") @db.Uuid
  contactId      String?   @map("contact_id") @db.Uuid
  buttonKey      String    @map("button_key")
  targetPath     String    @map("target_path")
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  clickCount     Int       @default(0) @map("click_count")
  firstClickedAt DateTime? @map("first_clicked_at") @db.Timestamptz
  lastClickedAt  DateTime? @map("last_clicked_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  campaign CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  CommunicationContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([campaignId, buttonKey])
  @@index([expiresAt])
  @@map("communication_redirect_tokens")
}

/**
 * Журнал попыток доставки (включая тестовые). Без содержимого сообщения и PII в логах.
 */
model CommunicationDeliveryAttempt {
  id                String   @id @default(uuid()) @db.Uuid
  campaignId        String?  @map("campaign_id") @db.Uuid
  contactId         String?  @map("contact_id") @db.Uuid
  isTest            Boolean  @default(false) @map("is_test")
  status            String
  provider          String
  errorCode         String?  @map("error_code")
  externalMessageId String?  @map("external_message_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  campaign CommunicationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contact  CommunicationContact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([campaignId, isTest, createdAt(sort: Desc)])
  @@index([isTest, createdAt(sort: Desc)])
  @@map("communication_delivery_attempts")
}
