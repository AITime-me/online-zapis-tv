  CALLBACK
  OPEN_LINK
  UNSUBSCRIBE
}

enum CommButtonStyle {
  PRIMARY
  POSITIVE
  NEGATIVE
  SECONDARY
}

enum CommEventType {
  IMPORTED
  EXCLUDED
  QUEUED
  ACCEPTED_BY_CHANNEL
  SEND_ERROR
  READ_CONFIRMED
  BUTTON_CLICKED
  LINK_OPENED
  REPLY_RECEIVED
  UNSUBSCRIBED
  LEAD_CREATED
  APPOINTMENT_CREATED
