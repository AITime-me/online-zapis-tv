  deliveryStatus      CommDeliveryStatus @default(UNKNOWN) @map("delivery_status")
  consentStatus       CommConsentStatus  @default(UNKNOWN) @map("consent_status")
  consentSource       String?            @map("consent_source")
  consentVersion      String?            @map("consent_version")
