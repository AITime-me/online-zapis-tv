generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  MASTER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentSource {
  INTERNAL
  ONLINE
  BOT
  PHONE
  OTHER
}

enum ScheduleBlockType {
  DAY_OFF
  VACATION
  SICK_LEAVE
  TRAINING
  DO_NOT_BOOK
  BREAK
  LUNCH
  PERSONAL
  TECHNICAL
}

enum EmergencyExportType {
  TODAY
  TOMORROW
  SEVEN_DAYS
  THIRTY_DAYS
  CUSTOM
}

enum EmergencyExportStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ExportStorage {
  LOCAL
  S3
}

enum ManagerNoteType {
  MANAGER
  OWNER
}

enum BookingRequestStatus {
  NEW
  CONTACTED
  CLOSED
}

enum BookingRequestType {
  MANAGER_REQUEST
  CONSULTATION_REQUEST
}

enum BookingRequestSource {
  ONLINE
}

enum PromotionType {
  GIFT
  SEASONAL
  GAME
  BUNDLE
  CONSULTATION
  CUSTOM
  DISCOUNT
}

enum DiscountUnit {
  PERCENT
  FIXED
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ClientStatus {
  NEW
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ClientDuplicateReviewStatus {
  REVIEW
  NOT_DUPLICATE
  POSTPONED
}

enum PromotionSource {
  MANUAL
  GAME
  VK
  BOT
  SEASONAL
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole
  name         String
  phone        String?
  positionTitle String?  @map("position_title")
  notes        String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  master              Master?
  createdAppointments   Appointment[]       @relation("AppointmentCreatedBy")
  createdBlocks         ScheduleBlock[]     @relation("BlockCreatedBy")
  createdExtraWorkWindows ExtraWorkWindow[] @relation("ExtraWorkCreatedBy")
  managerNotes          ManagerNote[]
  requestedExports      EmergencyExport[]   @relation("ExportRequestedBy")
  auditLogs             AuditLog[]
  clientDuplicateReviews ClientDuplicateReview[] @relation("DuplicateReviewedBy")
  clientsMergedBy        Client[]                @relation("ClientMergedBy")
  clientMergeLogs        ClientMergeLog[]        @relation("ClientMergePerformedBy")

  @@map("users")
}

model Master {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String?  @unique @map("user_id") @db.Uuid
  internalName           String   @map("internal_name")
  publicName             String   @map("public_name")
  clientDescription      String?  @map("client_description")
  photoUrl               String?  @map("photo_url")
  slotMinutes            Int      @default(30) @map("slot_minutes")
  workStart              String   @map("work_start")
  workEnd                String   @map("work_end")
  breakAfterMinutes      Int      @default(0) @map("break_after_minutes")
  usesDefaultWorkHours   Boolean  @default(false) @map("uses_default_work_hours")
  sortOrder              Int      @default(0) @map("sort_order")
  isActive               Boolean  @default(true) @map("is_active")
  isPublic               Boolean  @default(true) @map("is_public")
  isOnlineBookingEnabled Boolean  @default(true) @map("is_online_booking_enabled")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  masterServices   MasterService[]
  appointments     Appointment[]
  scheduleBlocks   ScheduleBlock[]
  extraWorkWindows ExtraWorkWindow[]
  bookingLinks     BookingLink[]
  bookingRequests  BookingRequest[]

  @@map("masters")
}

model ServiceCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  services Service[]

  @@map("service_categories")
}

model Service {
  id                     String   @id @default(uuid()) @db.Uuid
  categoryId             String   @map("category_id") @db.Uuid
  internalName           String   @map("internal_name")
  publicName             String   @map("public_name")
  clientDescription      String?  @map("client_description")
  durationMinutes        Int      @map("duration_minutes")
  breakAfterMinutes      Int      @default(0) @map("break_after_minutes")
  price                  Decimal? @db.Decimal(10, 2)
  priceFrom              Decimal? @map("price_from") @db.Decimal(10, 2)
  priceTo                Decimal? @map("price_to") @db.Decimal(10, 2)
  sortOrder              Int      @default(0) @map("sort_order")
  isActive               Boolean  @default(true) @map("is_active")
  isPublic               Boolean  @default(true) @map("is_public")
  isOnlineBookingEnabled Boolean  @default(true) @map("is_online_booking_enabled")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  category       ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  synonyms       ServiceSynonym[]
  masterServices MasterService[]
  appointments   Appointment[]
  bookingLinks   BookingLink[]
  promotions     PromotionService[]

  @@map("services")
}

model ServiceSynonym {
  id        String   @id @default(uuid()) @db.Uuid
  serviceId String   @map("service_id") @db.Uuid
  synonym   String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([serviceId, synonym])
  @@map("service_synonyms")
}

model MasterService {
  masterId                    String   @map("master_id") @db.Uuid
  serviceId                   String   @map("service_id") @db.Uuid
  isEnabled                   Boolean  @default(true) @map("is_enabled")
  isPublic                    Boolean  @default(true) @map("is_public")
  isOnlineBookingEnabled      Boolean  @default(true) @map("is_online_booking_enabled")
  durationMinutesOverride     Int?     @map("duration_minutes_override")
  breakAfterMinutesOverride   Int?     @map("break_after_minutes_override")
  priceOverride               Decimal? @map("price_override") @db.Decimal(10, 2)
  sortOrder                   Int      @default(0) @map("sort_order")
  createdAt                   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  master  Master  @relation(fields: [masterId], references: [id], onDelete: Restrict)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([masterId, serviceId])
  @@map("master_services")
}

model Appointment {
  id                        String            @id @default(uuid()) @db.Uuid
  masterId                  String            @map("master_id") @db.Uuid
  serviceId                 String?           @map("service_id") @db.Uuid
  startsAt                  DateTime          @map("starts_at") @db.Timestamptz
  endsAt                    DateTime          @map("ends_at") @db.Timestamptz
  clientName                String            @map("client_name")
  clientPhone               String            @map("client_phone")
  comment                   String?
  importantNote             String?           @map("important_note")
  isBold                    Boolean           @default(false) @map("is_bold")
  serviceDurationMinutes    Int?              @map("service_duration_minutes")
  breakAfterMinutes         Int?              @map("break_after_minutes")
  standardDurationMinutes   Int?              @map("standard_duration_minutes")
  standardBreakAfterMinutes Int?              @map("standard_break_after_minutes")
  isManualTimeOverride      Boolean           @default(false) @map("is_manual_time_override")
  status                    AppointmentStatus @default(SCHEDULED)
  source                    AppointmentSource @default(INTERNAL)
  promoCode                 String?           @map("promo_code")
  appliedPromotions         Json?             @map("applied_promotions")
  botSessionId              String?           @map("bot_session_id")
  manageToken               String?           @unique @map("manage_token")
  cancelledBy               String?           @map("cancelled_by")
  cancelReason              String?           @map("cancel_reason")
  rescheduleRequestText     String?           @map("reschedule_request_text")
  rescheduleRequestedAt     DateTime?         @map("reschedule_requested_at") @db.Timestamptz
  createdByUserId           String?           @map("created_by_user_id") @db.Uuid
  clientId                  String?           @map("client_id") @db.Uuid
  cancelledAt               DateTime?         @map("cancelled_at") @db.Timestamptz
  createdAt                 DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  master        Master   @relation(fields: [masterId], references: [id], onDelete: Restrict)
  service       Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdByUser User?    @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([masterId, startsAt, endsAt])
  @@index([startsAt])
  @@index([clientId])
  @@map("appointments")
}

model ScheduleBlock {
  id              String            @id @default(uuid()) @db.Uuid
  masterId        String?           @map("master_id") @db.Uuid
  blockDate       DateTime?         @map("block_date") @db.Date
  startsAt        DateTime?         @map("starts_at") @db.Timestamptz
  endsAt          DateTime?         @map("ends_at") @db.Timestamptz
  isFullDay       Boolean           @default(false) @map("is_full_day")
  blockType       ScheduleBlockType @map("block_type")
  internalReason  String?           @map("internal_reason")
  createdByUserId String?           @map("created_by_user_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  master        Master? @relation(fields: [masterId], references: [id], onDelete: Cascade)
  createdByUser User?   @relation("BlockCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([masterId, startsAt, endsAt])
  @@index([masterId, blockDate])
  @@index([startsAt])
  @@map("schedule_blocks")
}

model ExtraWorkWindow {
  id                     String   @id @default(uuid()) @db.Uuid
  masterId               String   @map("master_id") @db.Uuid
  workDate               DateTime @map("work_date") @db.Date
  startsAt               DateTime @map("starts_at") @db.Timestamptz
  endsAt                 DateTime @map("ends_at") @db.Timestamptz
  isOnlineBookingEnabled Boolean  @default(false) @map("is_online_booking_enabled")
  comment                String?
  createdByUserId        String?  @map("created_by_user_id") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  master        Master @relation(fields: [masterId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("ExtraWorkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([masterId, workDate])
  @@index([startsAt])
  @@map("extra_work_windows")
}

model ManagerNote {
  id              String          @id @default(uuid()) @db.Uuid
  noteDate        DateTime        @map("note_date") @db.Date
  noteType        ManagerNoteType @default(MANAGER) @map("note_type")
  content         String
  createdByUserId String?         @map("created_by_user_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([noteDate])
  @@index([noteDate, noteType])
  @@map("manager_notes")
}

model BookingLink {
  id           String    @id @default(uuid()) @db.Uuid
  token        String    @unique
  serviceId    String?   @map("service_id") @db.Uuid
  masterId     String?   @map("master_id") @db.Uuid
  source       String?
  promoCode    String?   @map("promo_code")
  botSessionId String?   @map("bot_session_id")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  isUsed       Boolean   @default(false) @map("is_used")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  master  Master?  @relation(fields: [masterId], references: [id], onDelete: SetNull)

  @@map("booking_links")
}

model BookingRequest {
  id          String               @id @default(uuid()) @db.Uuid
  clientName  String               @map("client_name")
  clientPhone String               @map("client_phone")
  comment     String?
  masterId    String?              @map("master_id") @db.Uuid
  status      BookingRequestStatus @default(NEW)
  source      BookingRequestSource @default(ONLINE)
  type        BookingRequestType
  clientId    String?              @map("client_id") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  master Master? @relation(fields: [masterId], references: [id], onDelete: SetNull)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([clientId])
  @@map("booking_requests")
}

model EmergencyExport {
  id                String                @id @default(uuid()) @db.Uuid
  exportType        EmergencyExportType   @map("export_type")
  periodFrom        DateTime              @map("period_from") @db.Date
  periodTo          DateTime              @map("period_to") @db.Date
  filePath          String?               @map("file_path")
  storage           ExportStorage         @default(LOCAL)
  status            EmergencyExportStatus @default(PENDING)
  errorMessage      String?               @map("error_message")
  requestedByUserId String?               @map("requested_by_user_id") @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz
  completedAt       DateTime?             @map("completed_at") @db.Timestamptz

  requestedByUser User? @relation("ExportRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("emergency_exports")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id") @db.Uuid
  payload        Json?
  previousValues Json?    @map("previous_values")
  newValues      Json?    @map("new_values")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model ChangeEvent {
  id                  String   @id @default(uuid()) @db.Uuid
  eventType           String   @map("event_type")
  entityType          String   @map("entity_type")
  entityId            String   @map("entity_id") @db.Uuid
  payloadAnonymized   Json?    @map("payload_anonymized")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@map("change_events")
}

model GameConfig {
  /** Singleton-конфигурация игры. */
  id          String   @id @default("default")
  isActive    Boolean  @default(false) @map("is_active")
  title       String   @default("Поймай своё время")
  description String   @default("")
  image       String?  @map("image")

  resultHeaderText     String @default("Ваш результат готов ✨") @map("result_header_text")
  directionLabelText   String @default("Ваше направление ухода:") @map("direction_label_text")
  giftLabelText        String @default("Ваш подарок:") @map("gift_label_text")
  ctaButtonText        String @default("Получить подарок и записаться") @map("cta_button_text")
  ctaButtonLink        String @default("/promo/procedure-gift") @map("cta_button_link")
  managerMessageHeader String @default("Здравствуйте!\n\nЯ прошла игру «Поймай своё время».") @map("manager_message_header")
  managerMessageFooter String @default("Хочу узнать условия получения подарка и записаться.") @map("manager_message_footer")

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("game_config")
}

model GameGift {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  shortDescription String   @map("short_description")
  image            String?  @map("image")
  isActive         Boolean  @default(true) @map("is_active")
  probability      Int      @default(0)

  /** Категоризация подарка для UI/аналитики. */
  priority  String @default("standard")
  cardStyle String @default("default") @map("card_style")

  /** Правила доступности: пустой массив = доступно для всех. */
  allowedGameDirections String[] @default([]) @map("allowed_game_directions")
  allowedResultTypes    String[] @default([]) @map("allowed_result_types")
  requiredPremiumLevel  Int      @default(0) @map("required_premium_level")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  plays GamePlay[]

  @@index([isActive])
  @@index([probability])
  @@map("game_gifts")
}

model GamePlay {
  id            String   @id @default(uuid()) @db.Uuid
  gameDirection String   @map("game_direction")
  skinNeed      String   @map("skin_need")
  resultType    String   @map("result_type")
  premiumLevel  Int      @default(0) @map("premium_level")

  selectedGiftId String?  @map("selected_gift_id") @db.Uuid
  selectedGift   GameGift? @relation(fields: [selectedGiftId], references: [id], onDelete: SetNull)

  /** Будущая связь с заявкой/лидом (например bookingRequest.id). */
  leadId String? @map("lead_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@index([gameDirection])
  @@index([resultType])
  @@index([selectedGiftId])
  @@map("game_plays")
}

model Promotion {
  id               String           @id @default(uuid()) @db.Uuid
  title            String
  slug             String           @unique
  shortDescription String?          @map("short_description")
  description      String?
  type             PromotionType
  status           PromotionStatus  @default(DRAFT)
  isActive         Boolean          @default(false) @map("is_active")
  startsAt         DateTime?        @map("starts_at") @db.Timestamptz
  endsAt           DateTime?        @map("ends_at") @db.Timestamptz
  giftTitle        String?          @map("gift_title")
  giftDescription  String?          @map("gift_description")
  discountValue    Decimal?         @map("discount_value") @db.Decimal(10, 2)
  discountUnit     DiscountUnit?    @map("discount_unit")
  discountDescription String?       @map("discount_description")
  conditions       String?
  ctaText          String?          @map("cta_text")
  ctaLink          String?          @map("cta_link")
  imageUrl         String?          @map("image_url")
  priority         Int              @default(100)
  source           PromotionSource  @default(MANUAL)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  services PromotionService[]

  @@index([status, isActive])
  @@index([priority])
  @@index([startsAt])
  @@index([endsAt])
  @@map("promotions")
}

model PromotionService {
  promotionId String @map("promotion_id") @db.Uuid
  serviceId   String @map("service_id") @db.Uuid

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([promotionId, serviceId])
  @@map("promotion_services")
}

model StudioSettings {
  /** Singleton-настройки студии. */
  id String @id @default("default")

  studioName  String @default("Твоё время") @map("studio_name")
  legalName   String @default("ИП Кузнецова Светлана Викторовна") @map("legal_name")
  inn         String @default("450144605881")
  ogrnip      String @default("324450000034680")
  phone       String @default("8 912 979-30-90")
  email       String @default("ipku82@bk.ru")
  address     String @default("г. Курган, ул. Володарского, 30")
  vkUrl       String @default("https://vk.me/tvoiovremya") @map("vk_url")
  maxUrl      String @default("https://web.max.ru/267619155") @map("max_url")
  telegramUrl String @default("") @map("telegram_url")
  whatsappUrl String @default("") @map("whatsapp_url")
  workingHoursText String @default("") @map("working_hours_text")

  bookingSuccessMessage String @default("Спасибо! Заявка отправлена. Менеджер студии свяжется с вами, чтобы уточнить детали и помочь с записью.") @map("booking_success_message")
  requestSuccessMessage String @default("Спасибо! Заявка отправлена. Менеджер студии свяжется с вами, чтобы уточнить детали и помочь с записью.") @map("request_success_message")
  gameSuccessMessage    String @default("Спасибо! Заявка отправлена. Менеджер студии свяжется с вами, чтобы уточнить детали и помочь с записью.") @map("game_success_message")

  privacyUrl String @default("/privacy") @map("privacy_url")
  termsUrl   String @default("/terms") @map("terms_url")
  consentUrl String @default("/consent") @map("consent_url")
  offerUrl   String @default("/offer") @map("offer_url")

  isOnlineBookingEnabled Boolean @default(true) @map("is_online_booking_enabled")
  isGameEnabled          Boolean @default(true) @map("is_game_enabled")
  isPromotionsEnabled    Boolean @default(true) @map("is_promotions_enabled")

  cookieBannerText String @default("Мы используем cookie, чтобы сайт работал корректно и становился удобнее. Продолжая пользоваться сайтом, вы соглашаетесь с использованием cookie.") @map("cookie_banner_text")
  cookieDetailsUrl String @default("/cookies") @map("cookie_details_url")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("studio_settings")
}

model LegalDocument {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String   @db.Text
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("legal_documents")
}

/**
 * Клиент студии — фундамент CRM.
 * В будущем: заявки, записи, задачи, переписки, лояльность, аналитика.
 */
model Client {
  id               String       @id @default(uuid()) @db.Uuid
  fullName         String       @map("full_name")
  phone            String?
  normalizedPhone  String?      @map("normalized_phone")
  email            String?
  birthDate     DateTime?    @map("birth_date") @db.Date
  gender        String?
  source        String?
  status        ClientStatus @default(NEW)
  notes         String?
  tags          String[]     @default([])
  isArchived    Boolean      @default(false) @map("is_archived")
  loyaltyLevel  String?      @map("loyalty_level")
  bonusBalance  Int          @default(0) @map("bonus_balance")
  totalSpent    Int          @default(0) @map("total_spent")
  lastVisitAt   DateTime?    @map("last_visit_at") @db.Timestamptz
  lastContactAt    DateTime?    @map("last_contact_at") @db.Timestamptz
  mergedIntoClientId String?    @map("merged_into_client_id") @db.Uuid
  mergedAt         DateTime?  @map("merged_at") @db.Timestamptz
  mergedByUserId   String?    @map("merged_by_user_id") @db.Uuid
  mergeNote        String?    @map("merge_note")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  appointments     Appointment[]
  bookingRequests  BookingRequest[]
  mergedIntoClient Client?        @relation("ClientMergeTarget", fields: [mergedIntoClientId], references: [id], onDelete: SetNull)
  mergedSources    Client[]       @relation("ClientMergeTarget")
  mergedByUser     User?          @relation("ClientMergedBy", fields: [mergedByUserId], references: [id], onDelete: SetNull)
  mergeLogsAsTarget ClientMergeLog[] @relation("MergeLogTarget")

  @@index([status, isArchived])
  @@index([phone])
  @@index([normalizedPhone])
  @@index([email])
  @@index([mergedIntoClientId])
  @@map("clients")
}

model ClientMergeLog {
  id              String   @id @default(cuid())
  targetClientId  String   @map("target_client_id") @db.Uuid
  sourceClientIds Json     @map("source_client_ids")
  mergedByUserId  String?  @map("merged_by_user_id") @db.Uuid
  reason          String?
  snapshot        Json
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  targetClient Client @relation("MergeLogTarget", fields: [targetClientId], references: [id], onDelete: Restrict)
  mergedByUser User?  @relation("ClientMergePerformedBy", fields: [mergedByUserId], references: [id], onDelete: SetNull)

  @@index([targetClientId, createdAt(sort: Desc)])
  @@map("client_merge_logs")
}

model ClientDuplicateReview {
  id               String                      @id @default(uuid()) @db.Uuid
  fingerprint      String                      @unique
  status           ClientDuplicateReviewStatus @default(REVIEW)
  note             String?
  reviewedByUserId String?                     @map("reviewed_by_user_id") @db.Uuid
  createdAt        DateTime                    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime                    @updatedAt @map("updated_at") @db.Timestamptz

  reviewedBy User? @relation("DuplicateReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("client_duplicate_reviews")
}
