# Environment template — скопируйте в файл вне Git.
#
# Staging:  cp .env.production.example .env.staging   + docker-compose.staging.yml   (APP_PORT=3000)
# Production: cp .env.production.example .env.production + docker-compose.production.yml (APP_PORT=3100)
#
# Никогда не коммитьте реальные значения. Не используйте password123 или dev-секреты.

# --- PostgreSQL (для docker-compose.production.yml / docker-compose.staging.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=tvoe_vremya

# Порт приложения на loopback хоста (контейнер слушает 3000 внутри)
# Staging:    APP_PORT=3000  → 127.0.0.1:3000
# Production: APP_PORT=3100  → 127.0.0.1:3100  (для reverse proxy)
APP_PORT=3100

# --- Приложение ---
NODE_ENV=production

# Строка подключения к PostgreSQL (в compose переопределяется для контейнера app)
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/tvoe_vremya

# Auth.js — единственный рекомендуемый секрет сессии (минимум 32 символа).
# NEXTAUTH_SECRET — устаревший fallback, не используйте в новых деплоях.
AUTH_SECRET=generate-with-openssl-rand-base64-32-or-longer

# Должен совпасть с публичным HTTPS-доменом после подключения reverse proxy.
AUTH_URL=https://your-domain.example

# Часовой пояс студии (Курган, UTC+5)
APP_TIMEZONE=Asia/Yekaterinburg

# Read-only ссылка для мастеров (/view/schedule?token=...) — длинный случайный токен
SCHEDULE_VIEW_TOKEN=generate-long-random-token-at-least-32-chars

# Аварийные XLSX (local + persistent volume в compose)
EXPORT_STORAGE=local
EXPORT_LOCAL_DIR=/app/exports/emergency

# Публичные контакты (опционально; иначе — значения из StudioSettings)
# NEXT_PUBLIC_STUDIO_PHONE=+79000000000
# NEXT_PUBLIC_STUDIO_PHONE_DISPLAY=+7 (900) 000-00-00

# В production запрещено:
# NEXT_PUBLIC_SCHEDULE_DEBUG=true

# Маркер окружения: development | staging | production
# Production compose фиксирует APP_ENV=production в docker-compose.production.yml.
# Для закрытого staging по SSH-туннелю: APP_ENV=staging и AUTH_URL=http://127.0.0.1:3000.
APP_ENV=production

# Доверять X-Forwarded-For / X-Real-IP только за reverse proxy (production/staging).
# Production compose по умолчанию: true. В dev оставьте unset/false.
TRUST_PROXY_HEADERS=true

# --- Почта (SMTP) ---
# MAIL_PROVIDER=disabled — почта выключена, приложение стартует без SMTP.
# MAIL_PROVIDER=smtp — включает отправку; тогда обязательны host/port/secure/user/password.
MAIL_PROVIDER=disabled
MAIL_FROM_NAME=Твоё время
MAIL_FROM_ADDRESS=your-smtp-address@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-address@example.com
# Пароль SMTP — только в закрытом .env.production на сервере, НЕ в Git.
SMTP_PASSWORD=
SMTP_IP_FAMILY=auto
