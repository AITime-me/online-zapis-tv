# Production/staging environment template — скопируйте в файл вне Git.
# Пример: cp .env.production.example .env.staging
#
# Никогда не коммитьте реальные значения. Не используйте password123 или dev-секреты.

# --- PostgreSQL (для docker-compose.staging.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=tvoe_vremya
APP_PORT=3000

# --- Приложение ---
NODE_ENV=production

# Строка подключения к PostgreSQL (в compose переопределяется для контейнера app)
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/tvoe_vremya

# Auth.js — единственный рекомендуемый секрет сессии (минимум 32 символа).
# NEXTAUTH_SECRET — устаревший fallback, не используйте в новых деплоях.
AUTH_SECRET=generate-with-openssl-rand-base64-32-or-longer
AUTH_URL=https://your-domain.example

# Часовой пояс студии (Курган, UTC+5)
APP_TIMEZONE=Asia/Yekaterinburg

# Read-only ссылка для мастеров (/view/schedule?token=...) — длинный случайный токен
SCHEDULE_VIEW_TOKEN=generate-long-random-token-at-least-32-chars

# Аварийные XLSX (на первом сервере — local + persistent volume)
EXPORT_STORAGE=local
EXPORT_LOCAL_DIR=/app/exports/emergency

# Публичные контакты (опционально; иначе используются значения из StudioSettings)
# NEXT_PUBLIC_STUDIO_PHONE=+79129793090
# NEXT_PUBLIC_STUDIO_PHONE_DISPLAY=+7 (912) 979-30-90

# В production запрещено:
# NEXT_PUBLIC_SCHEDULE_DEBUG=true

# Маркер окружения: development | staging | production
# Используется env-валидацией (AUTH_URL) и guard-скриптами (dev-seed).
# Реальный production: оставьте production — AUTH_URL разрешён только по https://.
# Закрытый staging по SSH-туннелю (AUTH_URL=http://127.0.0.1:3000): задайте staging —
# иначе вход падает с "AUTH_URL должен использовать HTTPS в production".
APP_ENV=production

# Доверять X-Forwarded-For / X-Real-IP только за reverse proxy (staging/production).
# В dev оставьте unset/false — иначе клиент сможет подменить IP через заголовки.
# TRUST_PROXY_HEADERS=true

# --- Почта (SMTP) ---
# MAIL_PROVIDER=disabled — почта выключена, приложение стартует без SMTP.
# MAIL_PROVIDER=smtp — включает отправку; тогда обязательны host/port/secure/user/password.
#
# Для служебной почты используется ОТДЕЛЬНЫЙ пароль внешнего приложения Mail.ru
# (право «Только отправка писем / SMTP»), НЕ основной пароль ящика.
# Реальный SMTP_PASSWORD задаётся только в закрытом server env, НЕ в Git и НЕ в чате.
MAIL_PROVIDER=smtp
MAIL_FROM_NAME=Твоё время
MAIL_FROM_ADDRESS=ipku82@bk.ru
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ipku82@bk.ru
# Пароль внешнего приложения Mail.ru — НЕ коммитить. Внести только на сервере.
SMTP_PASSWORD=
# Выбор IP-семейства для SMTP: auto (по умолчанию) | 4 (только A) | 6 (только AAAA).
# На staging при недоступности IPv4 к smtp.mail.ru задайте 6 — IP берётся из DNS,
# жёстко прописывать адрес Mail.ru нельзя; tls.servername остаётся smtp.mail.ru.
SMTP_IP_FAMILY=auto
