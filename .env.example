# PostgreSQL (локально через Docker; позже — Timeweb PostgreSQL 17)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tvoe_vremya

# Часовой пояс студии (Курган, UTC+5). В БД — UTC; в UI — время студии.
APP_TIMEZONE=Asia/Yekaterinburg

# Аварийная выгрузка (локально)
EXPORT_STORAGE=local
EXPORT_LOCAL_DIR=./exports/emergency

# Позже: S3 / Timeweb Object Storage
# S3_BUCKET=
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Шаг 2+: авторизация
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# Шаг позже: API для AI-бота (без персональных данных)
# BOT_API_KEY=
